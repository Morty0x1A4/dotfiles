{
    "layer": "top",
    "position": "top",
    "autohide": true,
    "autohide-blocked": false,
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "expand-right": true,
    "modules-left": [
	"custom/archicon",
        "niri/window"
    ],

    "modules-center": [
        "niri/workspaces",
    ],

    "modules-right": [
        "tray",
        "pulseaudio",
        "clock",
        "custom/exit"
    ],
    // Workspaces
    "niri/workspaces": {
      "on-click": "activate"
    },
  
    // Taskbar
    "wlr/taskbar": {
      "tooltip-format": "{title}",
      "on-click": "activate",
      "on-click-middle": "close",
      "ignore-list": ["Alacritty", "kitty", "ghostty"],
      "app_ids-mapping": {
        "firefoxdeveloperedition": "firefox-developer-edition"
      },
      "rewrite": {
        "Firefox Web Browser": "Firefox",
        "Foot Server": "Terminal"
      }
    },
  
    // niri Window
    "niri/window": {
      "format": "{}",
      "rewrite": {
        "(.*) - Brave": "$1",
        "(.*) - Chromium": "$1",
        "(.*) - Brave Search": "$1",
        "(.*) - Outlook": "$1",
        "(.*) Microsoft Teams": "$1"
      },
      "separate-outputs": true
    },
  
    // Empty
    "custom/empty": {
      "format": ""
    },
  
    // Tools
    "custom/tools": {
      "format": "",
      "tooltip-format": "Tools"
    },
  
    // Updates Count
    "custom/updates": {
        "format": "{} {icon}",
        "return-type": "json",
        "format-icons": {
            "has-updates": "󱍷",
            "updated": "󰂪"
        },
        "exec-if": "which waybar-module-pacman-updates",
        "exec": "waybar-module-pacman-updates --interval-seconds 5 --network-interval-seconds 300"
    },
  
    // fuzzel Application Launcher
    "custom/appmenu": {
      "format": "   ",
      "on-click": "sleep 0.2; fuzzel",
      "tooltip-format": "Left: Open the application launcher"
    },
  
    // Power Menu
    "custom/exit": {
      "format": " 󰐥 ",
      "on-click": "~/.config/waybar/scripts/power-menu.sh",
    },
  
    // Keyboard State
    "keyboard-state": {
      "numlock": true,
      "capslock": true,
      "format": "{name} {icon}",
      "format-icons": {
        "locked": "",
        "unlocked": ""
      }
    },
  
    // System tray
    "tray": {
      "icon-size": 16,
      "spacing": 8 
    },
  
    // Clock
    "clock": {
      "format": "{:%H:%M %d.%m.%y}",
      "tooltip-format": "<tt>{calendar}</tt>"
    },
  
    "niri/language": {
      "format": "/ K {short}"
    },
  
    // Pulseaudio
    "pulseaudio": {
      // "scroll-step": 1, // %, can be a float
      "format": "{icon} {volume}%",
      "format-bluetooth": "{volume}% {icon} {format_source}",
      "format-bluetooth-muted": " {icon} {format_source}",
      "format-muted": " {format_source}",
      "format-source": "{volume}% ",
      "format-source-muted": "",
      "format-icons": {
      },
      "on-click": "pavucontrol"
    },
  
    // Other
    "user": {
      "format": "{user}",
      "interval": 60,
      "icon": false
    },
  
    "custom/archicon": {
      "format": "󰻀",
      "on-click": "sleep 0.2; fuzzel",
      "tooltip": false
    }
}
